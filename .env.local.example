# ============================================================
# BUREAUCRACYAI / FormWise — Environment Variables Template
# Copy this file to .env.local and fill in real values.
# Never commit .env.local — it is gitignored.
# ============================================================

# --- AI Provider Selection ----------------------------------
# Default provider when the user has no preference set.
# Allowed: sirma | anthropic | openai | google | cohere | ollama
# Default: sirma (matches the hackathon configuration).
AI_PROVIDER=sirma

# --- Sirma AI (default in Phase 1) --------------------------
SIRMA_API_KEY=
SIRMA_AI_DOMAIN=https://stage.sirma.ai/
SIRMA_BASE_URL=https://stage.sirma.ai/client/api/v1
SIRMA_EMBEDDING_MODEL=text-embedding-3-small
SIRMA_AGENT_ID=

# --- Anthropic (Claude) -------------------------------------
ANTHROPIC_API_KEY=

# --- OpenAI (GPT + embeddings) ------------------------------
OPENAI_API_KEY=
# Optional: route through a compatible proxy / Azure endpoint
# OPENAI_BASE_URL=

# --- Google (Gemini) ----------------------------------------
GOOGLE_API_KEY=
# Alternative name accepted: GEMINI_API_KEY=

# --- Cohere -------------------------------------------------
COHERE_API_KEY=

# --- Ollama (local model server) ----------------------------
# Set OLLAMA_ENABLED=true to allow the router to use a local Ollama install.
OLLAMA_ENABLED=false
OLLAMA_BASE_URL=http://localhost:11434

# --- ChromaDB (RAG vector store) ----------------------------
# Local: http://localhost:8000
# Railway: https://your-chroma.up.railway.app
CHROMA_URL=http://localhost:8000

# --- UploadThing (file uploads) -----------------------------
UPLOADTHING_SECRET=
NEXT_PUBLIC_UPLOADTHING_APP_ID=

# --- Supabase (Phase 2: auth + database) --------------------
# Create a project at https://supabase.com and copy these from
# Project Settings → API. Leave empty to keep the localStorage
# fallback (development demo mode).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service-role key — server-side only, bypasses RLS.
# NEVER expose this to the client. NEVER prefix with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=

# --- Trial / Quota (Phase 2) --------------------------------
# Anonymous trial limit (free questions before signup is required).
TRIAL_MAX_USES=1
# Salt used to hash IPs for the trial counter. Change once per project,
# never share. If you change it, all anonymous trial counters reset.
TRIAL_HASH_SALT=change-me-to-something-long-and-random

# --- Upstash Redis (Phase 3 — distributed rate limiting) ---
# Create a free database at https://upstash.com → REST credentials.
# Without these, the rate limiter falls back to in-memory per-process,
# which doesn't share state across serverless cold starts.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Resend (Phase 3 — transactional email) ---
# Sign up at https://resend.com, verify your sender domain, then paste
# the API key. Required for password resets, deadline reminders, digests.
RESEND_API_KEY=
RESEND_FROM_EMAIL=FormWise <noreply@yourdomain.com>
RESEND_REPLY_TO=support@yourdomain.com

# --- LemonSqueezy (Phase 4 — billing) ---
# 1. Create a store at https://app.lemonsqueezy.com
# 2. API key: Settings → API → "Create API key"
# 3. Webhook secret: Settings → Webhooks → add endpoint at /api/billing/webhook
#    Events: subscription_*, order_created, order_refunded
# 4. Variant ids: open each product → copy the variant id (number)
# 5. (Optional) Document credit variant for pay-per-document at €2.
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_WEBHOOK_SECRET=
LEMONSQUEEZY_VARIANT_ID_PRO=
LEMONSQUEEZY_VARIANT_ID_BUSINESS=
LEMONSQUEEZY_VARIANT_ID_DOCUMENT_CREDIT=

# --- PostHog (Phase 5 — anonymous product analytics) ---
# Sign up at https://posthog.com (free tier: 1M events/month).
# Pick the EU host if your users are EU-based.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
NEXT_PUBLIC_APP_VERSION=0.1.0

# --- App ----------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Demo mode shows pre-cached answers and skips API calls.
# Useful for smoke tests without real credentials.
NEXT_PUBLIC_DEMO_MODE=false

# --- Developer Settings (Phase 1) ---------------------------
# When true, the Settings → Developer tab is visible and
# /api/settings/env returns env diagnostics. Auto-enabled in NODE_ENV=development.
# In production builds, leave this OFF.
NEXT_PUBLIC_DEV_SETTINGS=true
