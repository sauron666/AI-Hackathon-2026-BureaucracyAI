# ============================================================
# BUREAUCRACYAI - Environment Variables Template
# Copy this file to .env.local and fill in your actual values
# ============================================================

# --- Server-side Only (never prefix with NEXT_PUBLIC_) ---

# Anthropic API Key for Claude
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# OpenAI API Key for embeddings
OPENAI_API_KEY=sk-your-openai-key-here

# UploadThing Secret (from uploadthing.com dashboard)
UPLOADTHING_SECRET=sk_live_your-uploadthing-secret-here

# --- Exposed to Browser ---

# UploadThing App ID (public, safe to expose)
NEXT_PUBLIC_UPLOADTHING_APP_ID=your-uploadthing-app-id

# App URL for server-side API calls
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Enable demo mode (shows pre-cached answers, skips API calls)
NEXT_PUBLIC_DEMO_MODE=true

# --- ChromaDB ---

# ChromaDB server URL
# Local development: http://localhost:8000
# Docker: http://localhost:8000
CHROMA_URL=http://localhost:8000

# --- Optional: AI Provider Selection ---
# Uncomment to switch AI provider (default: anthropic)
# AI_PROVIDER=anthropic
